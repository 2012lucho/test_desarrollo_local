{
  "name": "base-backend",
  "version": "0.1.0",
  "private": true,
  "description": "API base NodeJS + Express + Knex + MariaDB",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate": "npx knex migrate:latest --knexfile src/knexfile.js",
    "migrate:rollback": "npx knex migrate:rollback --knexfile src/knexfile.js",
    "migrate:status": "npx knex migrate:status --knexfile src/knexfile.js"
  },
  "dependencies": {
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "knex": "^2.4.2",
    "mysql2": "^3.3.0",
    "mariadb": "^3.1.4",
    "socket.io": "^4.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
